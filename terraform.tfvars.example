################################################################################
# TEMPLATE FILE: terraform.tfvars.example
# INSTRUCTIONS: 
# 1. Copy this file to 'terraform.tfvars' (which is ignored by Git).
# 2. Replace the placeholder values with your actual configuration.
# 3. DO NOT commit your real 'terraform.tfvars' to version control.
################################################################################


###########################################
# GLOBAL
############################################
name         = "comapany-parts-eu-west-vpc"
project_name = "project-eks"
environment  = "dev"
region       = "eu-west-2"

tags = {
  Project     = "project-eks"
  Environment = "dev"
  Owner       = "team"
}

############################################
# VPC
############################################
vpc_cidr = "10.0.0.0/16"

public_subnet_cidrs = [
  "10.0.1.0/24",
  "10.0.2.0/24"
]

private_subnet_cidrs = [
  "10.0.3.0/24",
  "10.0.4.0/24"
]

azs = ["eu-west-2a", "eu-west-2b"]

############################################
# EKS
############################################
cluster_name    = "project-eks-cluster"
cluster_version = "1.30"

############################################
# NODE GROUP (NEW VARIABLE NAMES)
############################################
instance_type = "t3.small"
disk_size     = 20

desired_size = 2
min_size     = 1
max_size     = 3
